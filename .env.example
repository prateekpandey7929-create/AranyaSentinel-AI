# Roboflow Configuration
# Get your API key from Roboflow account settings -> Workspaces -> API Keys
ROBOFLOW_API_KEY=yrf_3yc2PainNQUN3hdKBocc83oqZkL2

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=forest_monitoring

# Google Earth Engine Configuration
# Required for modern ee.Initialize() in some environments.
# Specify your Google Cloud Project ID associated with GEE (e.g. 'ee-username' or custom project)
GEE_PROJECT=your_gee_gcp_project_id_here

# ---------------------------------------------------------
# SMTP & Smart Alert Configuration
# ---------------------------------------------------------
# SMTP Settings (Use App Password for Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_google_app_password

# Alert Roles
LOCAL_RANGER_EMAIL=ranger@example.com
HIGHER_AUTHORITY_EMAIL=admin@example.com

# Alert Threshold (Low, Medium, High, Critical)
# Only alerts with severity >= this threshold will trigger emails
ALERT_THRESHOLD=High
# Auto-escalation time (in minutes)
ESCALATION_MINUTES=5
